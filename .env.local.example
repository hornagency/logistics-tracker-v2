# ─── Admin Credentials ──────────────────────────────────────────────────────
# Username and password for the /admin/login page.
# These are server-side only — never exposed to the browser.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_before_deploy

# ─── Session Signing Secret ─────────────────────────────────────────────────
# Used to sign HMAC-SHA256 session tokens.
# Generate a strong random value: openssl rand -hex 32
ADMIN_SECRET=replace_with_64_char_random_hex_string

# ─── Database ────────────────────────────────────────────────────────────────
# Required. Use PostgreSQL for both local and production (Neon, Supabase, Railway).
# Local dev: create a free DB at neon.tech or supabase.com and paste the connection string here.
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# ─── Site URL (Production only) ───────────────────────────────────────────────
# Used to generate correct sitemap.xml and robots.txt.
# NEXT_PUBLIC_SITE_URL=https://vectoralogistics.com
